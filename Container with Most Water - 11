class Solution:
    def maxArea(self, height):
        low=0
        high=len(height)-1
        max_area=0
        while low < high:
            if height[low] < height[high]:
                area=height[low]*(high-low)
                low+=1
            else:
                area=height[high]*(high-low)
                high-=1
            if area > max_area:
                max_area=area
        return max_area